"31 MUH FIKRAN MAULANA",
"32 GIANTA",
"33 SALDIYANSYAH PUTRA",
"34 SRI ASHARI",
"35 INA HANSINA",
"36 REZKY ADITIA",
"37 ASTRI DUMA",
"38 NUR FAJRIAH",
"39 JAZZDY FEBRIART",
"40 DIDIEK EMPU",
"41 AHMAD FIKRI",
"42 ALMAGFIRAH",
"43 SALWA ATIKAH",
"44 MARWAH SHAYLAWATI",
"45 PUTRI NURFADILLAH",
"46 FERYSCA BADJANG",
"47 MUH ALFIAN",
"48 AHMAD FAUZI",
"49 DIAN ASTI",
"50 GIA NUR RAHMA",
"51 NADIYAH PUTRI",
"52 ADELIA ZAFIRA",
"53 NURFADILLAH UTAMI",
"54 ANDI ATTHAYA",
"55 MUH FAIZ ZAKY",
"56 NURCICI TAJJU",
"57 SYAHRUL RAMADHAN",
"58 MUH TASLIM",
"59 ANDI ASSIFFA",
"60 RESKY AURA",
"61 AFIFA AZZAHRA",
"62 ILLQNA PELANGI",
"63 ALINI AFIFAH",
"64 AHMAD RAFIQ",
"65 MUHAMMAD SYUKRI",
"66 ANDI VITA",
"67 SABILAH",
"68 NUR ASSIFA",
"69 AHMAD ABIZAR",
"70 ADELA FEBRIANTY",
"71 A ACHMAD HIDAYATULLAH",
"72 MATUAN",
"73 DWI REZKY ANDINI",
"74 LA ODDANG RIU",
"75 ALPANDI",
"76 GEMARIANG",
"77 FARHAN USMAN",
"78 SITI NABILA",
"79 NUR ZAHRA",
"80 MUHAMMAD NUR IMPARSYAL",
"81 MUH FATHIR ASHARY",
"82 NURRAHMAH",
"83 ANGELA GRACIA",
"84 KEYZHIA",
"85 MUHAMMAD FAHRUM",
"86 OKTOVIANUS",
"87 ARDIANSYAH",
"88 AI ISLAH",
"89 JIBRAN",
"90 ADITYA",
"91 SINDI",
"92 SRI RAHAYU",
"93 NURFAIDAH",
"94 MELVAYANTI",
"95 DEANOVA",
"96 ARSYIL",
"97 ALIF ANDI",
"98 MUH NABIL",
"99 WINDI",
"100 IFHON",
"101 AMIRAH",
"102 AVRILYA",
"103 ADELIA FEBRIANTI SAMMA",
"104 ANASTASIA ANSHAR",
"105 NADIYAH RAJAB",
"106 A NAYLASARI",
"107 IBNU RAFFI",
"108 MUHAMMAD FATIH",
"109 WULAN SARI",
"110 IDIL",
"111 MILDA",
"112 NURMUTHIA",
"113 FATHIR AL AHQAB",
"114 MUH TEGAR",
"115 INTAN PUSPITA",
"116 SURIANI",
"117 GALANG PAMUNGKAS",
"118 HAPIS",
"119 TINA",
"120 HAIKAL",
"121 BERNALDY",
"122 MUHAMMAD TENRI",
"123 AMANDA",
"124 MUGHNIY",
"125 ABD RAUF",
"126 AL FRIYANTI",
"127 FADIL ASRI",
"128 GRACE OKTAVIANY",
"129 SYELFIANA",
"130 AMELIA PRATIWI",
"131 ANDI CANDRA",
"132 ALIYA",
"133 MARDIVA",
"134 GEORGE LATIANG",
"135 NUR HIDAYAH",
"136 REYNALDI",
"137 NASYA PUTRI",
"138 NOVIA",
"139 AINUN",
"140 MUH NABIL FATTHA",
"141 NAJWA",
"142 SITI SALWA",
"143 MIKA ILEVEN"
];

// ======================
// DAFTAR PEMENANG (URUT)
// ======================
const winners = [
"103 ADELIA FEBRIANTI SAMMA",
"26 MUH HASBAR NOERHADI",
"133 MARDIVA",
"24 MUH SAHRUL",
"117 GALANG PAMUNGKAS",
"32 GIANTA",
"89 JIBRAN",
"68 NUR ASSIFA",
"81 MUH FATHIR ASHARY",
"42 ALMAGFIRAH"
];

let spinCount = 0;

const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");
const radius = 250;

// gambar roda
function drawWheel() {
  const angle = 2 * Math.PI / data.length;
  data.forEach((item, i) => {
    ctx.beginPath();
    ctx.moveTo(radius, radius);
    ctx.arc(radius, radius, radius, i * angle, (i + 1) * angle);
    ctx.fillStyle = i % 2 === 0 ? "#6ec6ff" : "#81c784";
    ctx.fill();
  });
}
drawWheel();

// fungsi spin
function spin() {
  if (spinCount >= winners.length) {
    alert("Semua pemenang sudah keluar!");
    return;
  }

  const target = winners[spinCount];
  const index = data.indexOf(target);

  if (index === -1) {
    alert("Data tidak cocok!");
    return;
  }

  const anglePerItem = 360 / data.length;
  const targetAngle = 360 - (index * anglePerItem);
  const extra = 360 * (5 + Math.random());

  canvas.style.transition = "transform 5s ease-out";
  canvas.style.transform = `rotate(${extra + targetAngle}deg)`;

  setTimeout(() => {
    alert("Pemenang: " + target);
    spinCount++;
  }, 5000);
}
</script>

</body>
</html>
