<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>Spin Wheel 143 Data</title>
<style>
body { text-align:center; font-family:Arial; }
#wheel {
  width:500px;
  height:500px;
  border-radius:50%;
  border:10px solid #333;
  margin:20px auto;
  transition: transform 5s ease-out;
  position:relative;
}
#pointer {
  width:0;
  height:0;
  border-left:20px solid transparent;
  border-right:20px solid transparent;
  border-bottom:40px solid red;
  margin:auto;
}
button {
  padding:10px 20px;
  font-size:16px;
}
</style>
</head>
<body>

<h2>SPIN UNDIAN</h2>
<div id="pointer"></div>
<canvas id="canvas" width="500" height="500"></canvas>
<br>
<button onclick="spin()">SPIN</button>

<script>
// ======================
// DATA (143)
// ======================
const data = [
"1 ARYA DWI CHANDRA",
"2 HERSONI LAMBA",
"3 UNTUNG NATANIEL LOMO",
"4 MUHAMMAD NUR ALIF AL.QADRI",
"5 ANASTASIA MASARRANG",
